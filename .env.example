# Telegram Bot Token (required)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Allowed user IDs (comma-separated, required)
ALLOWED_USERS=123456789,987654321

# Optional: move allowlist auth to root-managed files (recommended for production)
# COCO_AUTH_ENV_FILE=/etc/coco/auth/auth.env
# COCO_AUTH_META_FILE=/etc/coco/auth/allowed_users_meta.json

# Allowed group chat IDs (optional; comma-separated)
# If empty, any group containing an allowed user is accepted.
ALLOWED_GROUP_IDS=

# Assistant command to run in new windows (optional, defaults to codex)
ASSISTANT_COMMAND=codex

# Runtime mode (forced to app_server_only)
COCO_RUNTIME_MODE=app_server_only

# Session transcript path (optional, defaults to ~/.codex/sessions)
SESSIONS_PATH=~/.codex/sessions

# Directory browser root (optional, defaults to ~/env)
BROWSE_ROOT=~/env

# Per-group directory roots (optional):
# format: <chat_id>=<path>,<chat_id>=<path>
# example: -1001111111111=~/env/team-a,-1002222222222=~/env/team-b
GROUP_BROWSE_ROOTS=

# Monitor polling interval in seconds (optional, defaults to 2.0)
MONITOR_POLL_INTERVAL=2.0

# Echo user messages back from transcript stream (optional, defaults to false)
SHOW_USER_MESSAGES=false
